# NTorq XT Device Configuration
# Copy this file to .env and fill in your own values.
# Never commit .env to version control.

# Your bike's BLE device name (visible in nRF Connect under "Device Name")
NTORQ_DEVICE_NAME=TVST0XXXXXX

# Your bike's Bluetooth MAC address (visible in nRF Connect)
NTORQ_DEVICE_MAC=XX:XX:XX:XX:XX:XX
